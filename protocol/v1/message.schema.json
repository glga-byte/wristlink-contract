{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wristlink.app/contract/v1/message.schema.json",
  "title": "WristLink phone-to-watch message envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "id", "kind", "createdAt", "payload"],
  "properties": {
    "v": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "kind": {
      "enum": ["point", "timer", "note", "command"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "ttlSec": {
      "type": "integer",
      "minimum": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "point"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/pointPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "timer"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/timerPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "note"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/notePayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "command"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "#/$defs/commandPayload"
          }
        }
      }
    }
  ],
  "$defs": {
    "pointPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "lat", "lon"],
      "properties": {
        "intent": {
          "enum": ["navigate", "save_waypoint"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timerPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "durationSec"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "durationSec": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "notePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "commandPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object"
        }
      }
    }
  }
}
